{
  "name": "@botozap/sdk",
  "version": "0.1.0",
  "description": "SDK oficial da BotoZap — envie mensagens e gerencie clientes na WhatsApp Cloud API oficial, multi-tenant.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "prepublishOnly": "pnpm build"
  },
  "engines": {
    "node": ">=20.19"
  },
  "keywords": [
    "botozap",
    "whatsapp",
    "whatsapp-cloud-api",
    "whatsapp-business",
    "multi-tenant",
    "sdk"
  ],
  "license": "MIT",
  "homepage": "https://botozap.com.br",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bytecraft-fernando/botozap-js.git",
    "directory": "packages/sdk"
  },
  "bugs": {
    "url": "https://github.com/bytecraft-fernando/botozap-js/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "devDependencies": {
    "tsup": "^8.3.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  }
}
